import React, { useState } from 'react';
import { StyleSheet, Text, View, TouchableOpacity, SafeAreaView, ScrollView, Alert } from 'react-native';
// This is the new import for our local database
import AsyncStorage from '@react-native-async-storage/async-storage';

const BRISTOL_TYPES = [
  { id: 1, name: 'Type 1', desc: 'Hard lumps, like nuts' },
  { id: 2, name: 'Type 2', desc: 'Lumpy & sausage-like' },
  { id: 3, name: 'Type 3', desc: 'Sausage with cracks' },
  { id: 4, name: 'Type 4', desc: 'Smooth & soft snake' },
  { id: 5, name: 'Type 5', desc: 'Soft blobs, clear edges' },
  { id: 6, name: 'Type 6', desc: 'Mushy & fluffy pieces' },
  { id: 7, name: 'Type 7', desc: 'Entirely liquid' },
];

const AMOUNTS = [
  { id: 'small', label: 'Small' },
  { id: 'medium', label: 'Regular' },
  { id: 'large', label: 'Large' },
];

const PAIN_LEVELS = [
  { id: 0, label: 'None', emoji: '😌' },
  { id: 1, label: 'Mild', emoji: '😕' },
  { id: 2, label: 'Medium', emoji: '😣' },
  { id: 3, label: 'Bad', emoji: '😫' },
];

const STOOL_COLORS = [
  { id: 'brown', hex: '#8B5A2B', label: 'Brown' },
  { id: 'green', hex: '#7A9A5B', label: 'Green' },
  { id: 'yellow', hex: '#D4B856', label: 'Yellow' },
  { id: 'pale', hex: '#D2C1B0', label: 'Pale' },
  { id: 'black', hex: '#3B3C36', label: 'Black' },
  { id: 'red', hex: '#C25A5A', label: 'Red' },
];

export default function App() {
  const [selectedType, setSelectedType] = useState(null);
  const [selectedAmount, setSelectedAmount] = useState(null);
  const [selectedPain, setSelectedPain] = useState(null);
  const [selectedColor, setSelectedColor] = useState(null);

  // --- NEW DATABASE LOGIC ---
  const handleSave = async () => {
    // 1. Make sure he actually selected at least the main type before saving
    if (!selectedType) {
      Alert.alert("Hold up!", "Please select a consistency type first.");
      return;
    }

    // 2. Bundle the data with a unique ID and timestamp
    const newEntry = {
      id: Date.now().toString(), // Creates a unique ID based on the exact millisecond
      date: new Date().toISOString(), // Standardized date format
      type: selectedType,
      amount: selectedAmount,
      pain: selectedPain,
      color: selectedColor,
    };

    try {
      // 3. Open the "filing cabinet" and see if there are older logs
      const existingLogsString = await AsyncStorage.getItem('@gut_logs');
      const existingLogs = existingLogsString ? JSON.parse(existingLogsString) : [];

      // 4. Add the new log to the list of old logs
      const updatedLogs = [newEntry, ...existingLogs];

      // 5. Save the whole list back into the phone's storage
      await AsyncStorage.setItem('@gut_logs', JSON.stringify(updatedLogs));

      // 6. Give him a success message and clear the form for next time!
      Alert.alert("Success!", "Your daily drop-off has been logged.");
      setSelectedType(null);
      setSelectedAmount(null);
      setSelectedPain(null);
      setSelectedColor(null);

    } catch (error) {
      Alert.alert("Error", "Something went wrong saving your data.");
      console.error(error);
    }
  };

  return (
    <SafeAreaView style={styles.container}>
      <View style={styles.header}>
        <Text style={styles.title}>Daily Log</Text>
        <Text style={styles.subtitle}>Track your gut health</Text>
      </View>

      <ScrollView style={styles.scrollBody} showsVerticalScrollIndicator={false}>
        {/* Consistency Section */}
        <Text style={styles.sectionTitle}>Consistency</Text>
        <View style={styles.bristolContainer}>
          <ScrollView horizontal showsHorizontalScrollIndicator={false} contentContainerStyle={styles.scrollContainer}>
            {BRISTOL_TYPES.map((item) => (
              <TouchableOpacity 
                key={item.id} 
                style={[
                  styles.typeCard, 
                  selectedType === item.id && styles.selectedCard
                ]}
                onPress={() => setSelectedType(item.id)}
              >
                <Text style={[styles.typeName, selectedType === item.id && styles.selectedText]}>
                  {item.name}
                </Text>
                <Text style={[styles.typeDesc, selectedType === item.id && styles.selectedText]}>
                  {item.desc}
                </Text>
              </TouchableOpacity>
            ))}
          </ScrollView>
        </View>

        {/* Amount Section */}
        <Text style={styles.sectionTitle}>Amount</Text>
        <View style={styles.amountContainer}>
          {AMOUNTS.map((item) => (
            <TouchableOpacity 
              key={item.id} 
              style={[
                styles.amountPill, 
                selectedAmount === item.id && styles.selectedAmountPill
              ]}
              onPress={() => setSelectedAmount(item.id)}
            >
              <Text style={[styles.amountText, selectedAmount === item.id && styles.selectedText]}>
                {item.label}
              </Text>
            </TouchableOpacity>
          ))}
        </View>

        {/* Pain Level Section */}
        <Text style={styles.sectionTitle}>Pain / Discomfort</Text>
        <View style={styles.painContainer}>
          {PAIN_LEVELS.map((item) => (
            <TouchableOpacity 
              key={item.id} 
              style={[
                styles.painCard, 
                selectedPain === item.id && styles.selectedPainCard
              ]}
              onPress={() => setSelectedPain(item.id)}
            >
              <Text style={styles.emojiText}>{item.emoji}</Text>
              <Text style={[styles.painLabel, selectedPain === item.id && styles.selectedText]}>
                {item.label}
              </Text>
            </TouchableOpacity>
          ))}
        </View>

        {/* Color Section */}
        <Text style={[styles.sectionTitle, { marginTop: 20 }]}>Color</Text>
        <View style={styles.colorContainer}>
          {STOOL_COLORS.map((item) => (
            <TouchableOpacity 
              key={item.id} 
              style={[
                styles.colorCircle, 
                { backgroundColor: item.hex },
                selectedColor === item.id && styles.selectedColorCircle
              ]}
              onPress={() => setSelectedColor(item.id)}
            />
          ))}
        </View>
      </ScrollView>

      <View style={styles.footer}>
        <TouchableOpacity style={styles.logButton} onPress={handleSave}>
          <Text style={styles.buttonText}>Save Entry</Text>
        </TouchableOpacity>
      </View>
    </SafeAreaView>
  );
}

